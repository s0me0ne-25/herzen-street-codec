import sys
import argparse
import re
from collections import Counter
import hashlib
import json
import random


# Global dictionary data (loaded by load_dictionary())
DICT = None
# Global quiet mode flag (-q / --quiet)
QUIET = False


def log(message: str) -> None:
    """Print informational or progress message to stderr only if not in quiet mode."""
    if not QUIET:
        print(message, file=sys.stderr)


def encode():
    """Encode data stream from stdin to stdout using the loaded dictionary.

    Binary input (raw bytes):
      - Every 2 bytes form a 16-bit index → word from DICT["dict16"]
      - Final single byte (if odd length) → word from DICT["dict8"]
    Words are written to stdout separated by single spaces.

    Punctuation logic:
      1. Build cumulative probability ranges from DICT["punct"] once.
      2. EOS=True at start (forces capitalization of first word).
      3. After each word:
         - If EOS: capitalize word and reset flag.
         - Generate random 0..10000.
         - If falls into a punctuation range, append the punctuation mark.
         - If punctuation is [.?!], set EOS=True for the next word.
    All logging goes exclusively to stderr (suppressed by -q).
    Output text (words + punctuation) is written in CP-1251 encoding.
    """
    log("Starting encoding stream...")

    # 1. Build punctuation probability ranges once
    punct_ranges = []
    cumulative = 0
    for char, prob in DICT["punct"]:
        if prob > 0:
            start = cumulative
            cumulative += prob
            end = cumulative - 1
            punct_ranges.append((start, end, char))

    EOS = True
    first = True

    while True:
        data = sys.stdin.buffer.read(2)
        if not data:
            break

        if len(data) == 2:
            idx = int.from_bytes(data, 'big')
            word = DICT["dict16"][idx]
        elif len(data) == 1:
            idx = data[0]  # 0..255
            word = DICT["dict8"][idx]
        else:
            break

        # Capitalize if this is the start of a new sentence
        if EOS:
            if word:
                word = word[0].upper() + word[1:]
            EOS = False

        # Output the word (in CP-1251)
        if not first:
            sys.stdout.buffer.write(b' ')
        sys.stdout.buffer.write(word.encode('cp1251'))
        first = False

        # Decide whether to add punctuation after the word
        rand = random.randint(0, 10000)
        for start, end, char in punct_ranges:
            if start <= rand <= end:
                if char == "—":
                    sys.stdout.buffer.write(b' ')  # space before em-dash
                sys.stdout.buffer.write(char.encode('cp1251'))
                if char in {'.', '?', '!'}:
                    EOS = True
                break  # only one punctuation per word

    sys.stdout.buffer.write(b'\n')  # final newline
    sys.stdout.buffer.flush()
    log("Encoding completed.")


def decode():
    """Decode data stream from stdin to stdout using the loaded dictionary.

    Input is text in CP-1251 encoding.
    Each token is cleaned (keep only Cyrillic letters [А-Яа-яЁё], lowercase).
    Lookup order: reverse_dict16 first (2 bytes), then reverse_dict8 (1 byte).
    If word is not found in either dictionary - log a warning and skip it.
    Output is raw binary bytes (no separators).
    """
    log("Starting decoding stream...")

    # Read entire input as CP-1251 bytes
    raw = sys.stdin.buffer.read()
    try:
        text = raw.decode('cp1251')
    except UnicodeDecodeError as e:
        log(f"Warning: CP-1251 decode error: {e}")
        text = raw.decode('cp1251', errors='replace')

    tokens = re.findall(r'\S+', text)

    for token in tokens:
        # 2. Clean token: keep only Cyrillic letters and force lowercase
        clean_word = re.sub(r'[^А-Яа-яЁё]', '', token).lower()
        if not clean_word:
            continue

        # 3. Lookup: 16-bit first, then 8-bit
        idx = DICT["reverse_dict16"].get(clean_word)
        if idx is not None:
            sys.stdout.buffer.write(idx.to_bytes(2, 'big'))
            continue

        idx = DICT["reverse_dict8"].get(clean_word)
        if idx is not None:
            sys.stdout.buffer.write(idx.to_bytes(1, 'big'))
            continue

        # 4. Word not found
        log(f"Warning: word not found in dictionary: '{token}' (clean: '{clean_word}')")

    sys.stdout.buffer.flush()
    log("Decoding completed.")


def make_dictionary(infile: str, outfile: str):
    """
    Generate encoding/decoding dictionary from a plaintext UTF-8 file.
    Currently processes data in memory only (outfile writing is now implemented).

    Processing steps for cyrillic_words:
      Pass 1 - Register normalization
      Pass 2 - Sorting in Russian alphabetical order
      Pass 3 - Deduplication
      Pass 4 - Isolation of proper names
      Stage 5 - Minimum size check (>= 65792)
      Stage 6 - Iterative thinning to exactly 65792 words
      Stage 7 - Extraction of 8-bit dictionary (256 evenly distributed words)
      Stage 8 - Final dictionary JSON formation and write to outfile
                (SHA-256 checksum of dict8 + dict16, punct probabilities)

    The dictionary is now written to outfile with 2-space indentation.
    """
    try:
        with open(infile, 'r', encoding='utf-8') as f:
            text = f.read()
    except FileNotFoundError:
        print(f"Error: File '{infile}' not found.", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"Error reading file '{infile}': {e}", file=sys.stderr)
        sys.exit(1)

    # 2. Count each punctuation mark separately
    punctuation = ".,?!—:"
    punct_count = Counter(c for c in text if c in punctuation)

    # Additional calculation at the end of stage #2:
    # words_gross = (number of occurrences of one or more consecutive whitespace characters) + 1
    words_gross = len(re.findall(r'\s+', text)) + 1

    # 3. Extract exclusively Cyrillic words, preserving original case
    cyrillic_words = re.findall(r'[А-Яа-яЁё]+', text)

    log(f"Initial Cyrillic words extracted: {len(cyrillic_words)}")

    # === Pass 1: Register normalization ===
    log("Stage 1: Register normalization...")
    normal_pattern = re.compile(r'^[А-Яа-яЁё][а-яё]*$')
    normalized = []
    for word in cyrillic_words:
        if not normal_pattern.match(word):
            word = word.lower()
        normalized.append(word)
    cyrillic_words = normalized
    log(f"After register normalization: {len(cyrillic_words)} words")

    # === Pass 2: Sorting dictionary ===
    log("Stage 2: Sorting dictionary...")
    cyrillic_words = sorted(cyrillic_words)
    log(f"After sorting: {len(cyrillic_words)} words")

    # === Pass 3: Deduplication ===
    log("Stage 3: Deduplication...")
    seen = set()
    unique_words = []
    for word in cyrillic_words:
        if word not in seen:
            unique_words.append(word)
            seen.add(word)
    cyrillic_words = unique_words
    log(f"After deduplication: {len(cyrillic_words)} unique words")

    # === Pass 4: Isolation of proper names ===
    log("Stage 4: Isolation of proper names...")
    word_set = set(cyrillic_words)
    to_remove = set()
    for word in cyrillic_words:
        if word and word[0].islower():
            capital_word = word[0].upper() + word[1:]
            if capital_word in word_set:
                to_remove.add(capital_word)
    cyrillic_words = [word for word in cyrillic_words if word not in to_remove]
    log(f"After proper name isolation: {len(cyrillic_words)} words")

    # === Stage 5: Minimum dictionary size check ===
    log("Stage 5: Checking minimum dictionary size...")
    min_size = 65536 + 256  # 65792
    if len(cyrillic_words) < min_size:
        print(f"Processed dictionary size is {len(cyrillic_words)}, "
              f"need {min_size} at least. "
              f"Add more source texts into '{infile}' and repeat.",
              file=sys.stderr)
        sys.exit(1)
    log(f"Dictionary size check passed: {len(cyrillic_words)} words")

    # === Stage 6: Iterative thinning of the dictionary ===
    if len(cyrillic_words) > min_size:
        log("Stage 6: Iterative thinning of dictionary to exactly 65792 words...")
        target = min_size
        iteration = 0

        while len(cyrillic_words) > target:
            iteration += 1
            N = len(cyrillic_words)
            excess = N - target
            step = max(2, int(N / excess) + 1 if excess > 0 else 2)
            
            log(f"Iteration {iteration}: current size = {N:,}, deletion step = {step}")
            
            cyrillic_words = [word for i, word in enumerate(cyrillic_words) if i % step != 0]
            log(f"  -> after iteration {iteration}: {len(cyrillic_words):,} words")
        
        log(f"Stage 6 completed successfully. Final dictionary size: {len(cyrillic_words)}")
    else:
        log(f"Dictionary size is exactly {min_size} - no thinning needed")

    # === Stage 7: Formation of 8-bit dictionary ===
    log("Stage 7: Forming 8-bit dictionary...")
    step_8bit = 257
    cyrillic_words_8bit = cyrillic_words[::step_8bit]
    log(f"Extracted {len(cyrillic_words_8bit)} words for 8-bit dictionary")

    cyrillic_words = [word for i, word in enumerate(cyrillic_words) if i % step_8bit != 0]
    log(f"Main 16-bit dictionary size after extraction: {len(cyrillic_words)} words")

    # === Stage 8: Forming final dictionary for saving to file ===
    log("Stage 8: Forming final dictionary JSON...")

    log("Calculating dictionary SHA-256 checksum...")
    dict_concat = " ".join(cyrillic_words_8bit + cyrillic_words)
    dict_sha256 = hashlib.sha256(dict_concat.encode('utf-8')).hexdigest()

    log("Calculating punctuation probabilities...")
    punct_list = []
    for punct_char in punctuation:
        count = punct_count.get(punct_char, 0)
        if words_gross > 0:
            prob_scaled = int((count * 10000) / words_gross)
        else:
            prob_scaled = 0
        punct_list.append([punct_char, prob_scaled])

    json_data = {
        "dict_sha256": dict_sha256,
        "punct": punct_list,
        "dict8": cyrillic_words_8bit,
        "dict16": cyrillic_words
    }

    log(f"Writing dictionary to '{outfile}'...")
    try:
        with open(outfile, 'w', encoding='utf-8') as f:
            json.dump(json_data, f, ensure_ascii=False, indent=2)
        log(f"Dictionary successfully written to '{outfile}' "
            f"({len(cyrillic_words_8bit)} 8-bit + {len(cyrillic_words)} 16-bit words)")
    except Exception as e:
        print(f"Error writing to '{outfile}': {e}", file=sys.stderr)
        sys.exit(1)


def load_dictionary(infile: str):
    """
    Internal function: load dictionary from JSON file into global DICT variable.
    """
    global DICT

    log(f"Loading dictionary from '{infile}'...")
    
    try:
        with open(infile, 'r', encoding='utf-8') as f:
            DICT = json.load(f)
    except Exception as e:
        print(f"Error loading dictionary file '{infile}': {e}", file=sys.stderr)
        sys.exit(1)

    log("Verifying dictionary SHA-256 checksum...")
    dict_concat = " ".join(DICT.get("dict8", []) + DICT.get("dict16", []))
    calculated_sha = hashlib.sha256(dict_concat.encode('utf-8')).hexdigest()
    
    if calculated_sha != DICT.get("dict_sha256"):
        print("Error: Dictionary integrity check failed (SHA-256 mismatch)!", file=sys.stderr)
        sys.exit(1)
    log("Dictionary checksum verification passed.")

    if len(DICT.get("dict8", [])) != 256:
        print(f"Error: dict8 must contain exactly 256 words (found {len(DICT.get('dict8', []))})", file=sys.stderr)
        sys.exit(1)
    if len(DICT.get("dict16", [])) != 65536:
        print(f"Error: dict16 must contain exactly 65536 words (found {len(DICT.get('dict16', []))})", file=sys.stderr)
        sys.exit(1)

    log("Building reverse dictionaries for decoding...")

    reverse_dict8 = {}
    for idx, word in enumerate(DICT["dict8"]):
        lower_word = word.lower()
        if lower_word in reverse_dict8:
            print(f"Error: Duplicate in dict8 after lowercasing!\n"
                  f"  Word '{word}' (index {idx:02X}) collides with previous entry.", file=sys.stderr)
            sys.exit(1)
        reverse_dict8[lower_word] = idx

    reverse_dict16 = {}
    for idx, word in enumerate(DICT["dict16"]):
        lower_word = word.lower()
        if lower_word in reverse_dict16:
            print(f"Error: Duplicate in dict16 after lowercasing!\n"
                  f"  Word '{word}' (index {idx:04X}) collides with previous entry.", file=sys.stderr)
            sys.exit(1)
        reverse_dict16[lower_word] = idx

    DICT["reverse_dict8"] = reverse_dict8
    DICT["reverse_dict16"] = reverse_dict16

    if len(DICT["reverse_dict8"]) != 256:
        print(f"Error: reverse_dict8 size ({len(DICT['reverse_dict8'])}) != 256", file=sys.stderr)
        sys.exit(1)
    if len(DICT["reverse_dict16"]) != 65536:
        print(f"Error: reverse_dict16 size ({len(DICT['reverse_dict16'])}) != 65536", file=sys.stderr)
        sys.exit(1)
    
    log(f"Dictionary loaded successfully: {len(DICT['dict8'])} (8-bit) + {len(DICT['dict16'])} (16-bit) words")


def main():
    parser = argparse.ArgumentParser(
        description="Herzen-Street codec prototype",
        prog="hest"
    )
    group = parser.add_mutually_exclusive_group(required=True)
    group.add_argument('-e', '--encode', action='store_true',
                       help='encoding mode (stdin -> stdout)')
    group.add_argument('-d', '--decode', action='store_true',
                       help='decoding mode (stdin -> stdout)')
    group.add_argument('--mkdict', nargs=2, metavar=('INFILE', 'OUTFILE'),
                       help='generate encoding/decoding dictionary from '
                            'plaintext UTF-8 file INFILE')
    parser.add_argument('--dict', metavar='DICTFILE',
                        help='path to dictionary JSON file (required for -e and -d)')
    parser.add_argument('-q', '--quiet', action='store_true',
                        help='quiet mode: suppress ALL logging to stderr')

    args = parser.parse_args()

    global QUIET
    QUIET = args.quiet

    if (args.encode or args.decode) and not args.dict:
        parser.error("--dict DICTFILE is required when using -e or -d")

    if args.encode:
        load_dictionary(args.dict)
        encode()
    elif args.decode:
        load_dictionary(args.dict)
        decode()
    elif args.mkdict:
        infile, outfile = args.mkdict
        make_dictionary(infile, outfile)


if __name__ == "__main__":
    main()
